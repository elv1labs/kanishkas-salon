# ============================================================
# Kanishka's Family Salon & Academy — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in all required values.
# Variables marked [REQUIRED] must be set. Others are optional.
#
# Generate a secure NextAuth secret:
#   openssl rand -base64 32
# ============================================================

# ── App URL [REQUIRED] ────────────────────────────────────────
# Public-facing URL (no trailing slash). Used for redirects, OG tags, etc.
# For local dev: http://localhost:3000
# For production: https://kanishkassalon.com
NEXT_PUBLIC_APP_URL=http://your-server-ip-or-domain

# ── Database [REQUIRED] ───────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kanishkas_salon?schema=public"
# Direct URL (used by Prisma migrate — bypasses connection pooler if any)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/kanishkas_salon"

# ── NextAuth [REQUIRED] ───────────────────────────────────────
# Must match NEXT_PUBLIC_APP_URL exactly (no trailing slash)
NEXTAUTH_URL=http://your-server-ip-or-domain
# Random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# ── Business Info [REQUIRED] ──────────────────────────────────
# Displayed on public pages, emails, and meta tags
NEXT_PUBLIC_SALON_NAME="Kanishka's Family Salon & Academy"
NEXT_PUBLIC_SALON_PHONE="+919171230292"
NEXT_PUBLIC_SALON_EMAIL="kanishkasen100@gmail.com"
NEXT_PUBLIC_SALON_ADDRESS="Anand Bazar, Baikunth Dham, Indore, Madhya Pradesh 452001"
NEXT_PUBLIC_SALON_LAT="22.7196"
NEXT_PUBLIC_SALON_LNG="75.8577"

# ── Node Environment ──────────────────────────────────────────
# Set to 'production' on the VPS. Never commit 'development' to prod.
NODE_ENV=development

# ── Google OAuth [OPTIONAL] ───────────────────────────────────
# Required if you enable "Sign in with Google" on the login page.
# Create at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Email (Resend) [OPTIONAL] ─────────────────────────────────
# Required for sending appointment confirmation and notification emails.
# Get key at: https://resend.com
# RESEND_API_KEY=re_your_api_key

# ── SMS (Twilio) [OPTIONAL] ───────────────────────────────────
# Required for SMS appointment reminders and WhatsApp booking webhook.
# Activation: npm install twilio, then set these vars.
# Get credentials at: https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE=+1234567890

# ── WhatsApp Business API [OPTIONAL] ──────────────────────────
# Meta Cloud API for WhatsApp booking notifications.
# Requires: Meta Business Account + verified phone number + approved templates.
# Set WHATSAPP_ENABLED=true to activate (disabled by default).
# Docs: https://developers.facebook.com/docs/whatsapp/cloud-api
# WHATSAPP_ENABLED=false
# WHATSAPP_API_TOKEN=EAAxxxxxxxx
# WHATSAPP_PHONE_ID=123456789012345

# ── Google Maps [OPTIONAL] ────────────────────────────────────
# Required for the interactive map on the Contact page.
# Get key at: https://console.cloud.google.com/apis/credentials
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── Media Uploads ─────────────────────────────────────────────
# Uploaded images are stored in public/uploads/ (Docker: persisted via
# the 'uploads_data' named volume). No env var needed — path is hardcoded.
# ⚠️  NEVER run `docker compose down -v` in production — deletes all images.

# ── Error Monitoring (Sentry) [OPTIONAL] ──────────────────────
# Set up a free project at: https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=kanishkas-salon

# ── Cron / Reminders [OPTIONAL] ───────────────────────────────
# Secret for authenticating the appointment reminder cron endpoint.
# CRON_SECRET=change-me-in-production

# ── S3-Compatible Backups [OPTIONAL] ──────────────────────────
# For automated off-site database backup uploads (Backblaze B2, AWS S3, MinIO).
# BACKUP_S3_BUCKET=your-bucket-name
# BACKUP_AWS_ACCESS_KEY_ID=your-access-key
# BACKUP_AWS_SECRET_ACCESS_KEY=your-secret-key
# BACKUP_AWS_REGION=us-east-1

# ── Google Reviews [OPTIONAL] ─────────────────────────────────
# Google Business Profile review link.
# Get yours from: Google Business Profile → Share review form → Copy link
# GOOGLE_REVIEW_URL=https://g.page/r/your-business/review
